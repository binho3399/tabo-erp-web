{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": "20.19.0",
    "pnpm": ">=10.19.0"
  },
  "scripts": {
    "dev": "vite",
    "env:check": "node scripts/validate-env.mjs",
    "typecheck": "tsc -b",
    "build": "pnpm env:check && tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server && node scripts/prerender.mjs && node scripts/check-bundle-size.mjs",
    "build:app": "pnpm env:check && tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server && node scripts/prerender.mjs",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "ci": "pnpm env:check && pnpm lint && pnpm typecheck && pnpm build && pnpm check:bundle && pnpm format:check",
    "push": "./scripts/push.sh",
    "pull": "./scripts/pull.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.2.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "zod": "^4.3.6",
    "zod-validation-error": "^4.0.2"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,md,yml,yaml}": "prettier --write"
  }
}
